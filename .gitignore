.DS_Store
.build/
.build-cache/
.swiftpm/
.cache/

# Local experiments are not part of the Rune app path.
go/

# Packaged .app from scripts/build-macos-app.sh (reproducible via swift build).
dist/

# Generated locally by fake-k3s (contains certificates) and should never be committed to main.
assets/readme/kubeconfig.fake-cluster.yaml

# Local fake-k8s runtime state, wrappers, kubeconfig, and shell env exports.
.rune-fake-k8s/

# Generated test reports / local CI exports.
rune-smoke-swift-testing.xml
test-reports/

# Full UI smoke screenshot runs are local review artifacts. README-linked
# update screenshots are kept as a narrow exception.
assets/screenshot/ui/*
!assets/screenshot/ui/update260429/
!assets/screenshot/ui/update260429/*.png

# Environment files should stay local; commit examples instead.
.env
.env.*
!.env.example
!**/.env.example
